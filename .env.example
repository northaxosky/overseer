# Local configuration for the opt-in test harnesses.
# Copy this to `.env` (gitignored) and set the paths for your machine.
# Real shell environment variables take precedence over `.env`.

# Read-only live-install harness (crates/overseer-core/tests/live_install.rs):
# a real Fallout 4 game directory (the folder containing Fallout4.exe).
# Use forward slashes, and quote any path containing spaces.
OVERSEER_FO4_DIR="C:/path/to/Steam/steamapps/common/Fallout 4"

# Destructive deploy/purge e2e (crates/overseer-core/tests/testbed_e2e.rs, #[ignore]d).
# Point this at a DISPOSABLE testbed copy — never your real game. As a safety gate the
# test refuses to run unless a marker file `.overseer-e2e-testbed` (containing the magic
# string it checks for) sits in this directory, so a wrong path can never touch a real
# install. Run it with: cargo test -p overseer-core --test testbed_e2e -- --ignored
# OVERSEER_FO4_TESTBED="F:/Workspace/overseer-testbed/steamapps/common/Fallout 4"
