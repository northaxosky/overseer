# Local configuration for opt-in test harnesses.
# Copy this to `.env` (gitignored) and set paths for your machine.
# Real shell environment variables take precedence over `.env`.
# Use forward slashes, and quote any path containing spaces.

# Hermetic baseline:
# cargo test

# Read-only live Fallout 4 install harness.
# Used by: crates/overseer-core/tests/live_install.rs
# Run with:
# cargo test -p overseer-core --test live_install -- --ignored --nocapture
# OVERSEER_FO4_DIR="C:/path/to/Steam/steamapps/common/Fallout 4"

# Read-only live Mod Organizer 2 instance harness.
# Used by: crates/overseer-core/tests/live_mo2.rs
# Run with:
# cargo test -p overseer-core --test live_mo2 -- --ignored --nocapture
# OVERSEER_MO2_INSTANCE="C:/path/to/Mod Organizer 2/instance"

# Destructive disposable Fallout 4 copy harness.
# Used by: crates/overseer-core/tests/testbed_e2e.rs
# Requires `<game dir>/.overseer-e2e-testbed` containing the marker magic.
# Run with:
# cargo test -p overseer-core --test testbed_e2e -- --ignored --nocapture --test-threads=1
# OVERSEER_FO4_TESTBED="F:/Workspace/overseer-testbed/steamapps/common/Fallout 4"

# Curated real-mod source for the destructive real-mod round-trip.
# Used by: crates/overseer-core/tests/testbed_e2e.rs
# Must point at an Overseer/MO2-style instance root containing `mods/`.
# OVERSEER_TESTBED="F:/Workspace/overseer-testbed/instance"
